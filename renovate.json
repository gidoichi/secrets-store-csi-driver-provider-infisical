{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration"
  ],
  "branchConcurrentLimit": 0,
  "labels": [
    "dependencies"
  ],
  "schedule": "* * 1-7 * 6",
  "git-submodules": {
    "enabled": true
  },
  "hostRules": [
    {
      "description": "token: https://app.docker.com/accounts/gidoichi/settings/personal-access-tokens > https://developer.mend.io/github/gidoichi/secrets-store-csi-driver-provider-infisical",
      "matchHost": "dhi.io",
      "username": "gidoichi",
      "password": "{{ secrets.DOCKERHUB_TOKEN }}"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "helm repo add \\S* (?<registryUrl>\\S+?)\\s+helm install .*/(?<depName>.*?) --version (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?) versioning=(?<versioning>.*?)\\s+\\S+: (?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{{versioning}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "image: (?<depName>.*?):(?<currentValue>.*)\\s"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/gidoichi/secrets-store-csi-driver-provider-infisical"
      ],
      "enabled": false
    },
    {
      "groupName": "dependencies",
      "recreateWhen": "always",
      "commitMessagePrefix": "[update:patch]",
      "matchPackageNames": [
        "*"
      ],
      "automerge": true,
      "addLabels": [
        "automerge"
      ]
    }
  ]
}
